[Unit]
Description=TikTok Mod Telegram Bot
After=network.target tiktok-mod-mysql.service
Wants=tiktok-mod-mysql.service

[Service]
Type=simple
User=tiktok
WorkingDirectory=/opt/tiktok-mod
ExecStart=/usr/bin/xvfb-run -a /usr/bin/node src/index.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
